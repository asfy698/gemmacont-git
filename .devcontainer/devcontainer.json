{
  "name": "gemma-gpu",
  "image": "python:3.12",
  "runArgs": ["--gpus=all"],

  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "FastAPI Server",
      "onAutoForward": "openBrowser"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python"]
    }
  }
}